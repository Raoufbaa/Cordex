<ui:FluentWindow
    x:Class="Cordex.UpdateWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    Title="Cordex Update"
    Width="500"
    Height="350"
    WindowStartupLocation="CenterScreen"
    ResizeMode="NoResize"
    Background="#1E1F22"
    ExtendsContentIntoTitleBar="True"
    WindowBackdropType="Mica">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Title Bar -->
        <ui:TitleBar Grid.Row="0" Title="Cordex Update" />

        <!-- Content -->
        <StackPanel Grid.Row="1" Margin="30,20,30,20">
            
            <!-- Icon -->
            <ui:SymbolIcon x:Name="IconSymbol" Symbol="ArrowDownload24" 
                          FontSize="48" Foreground="#00B0F4" 
                          HorizontalAlignment="Center" Margin="0,0,0,20"/>

            <!-- Title -->
            <TextBlock x:Name="TitleText" Text="Update Available" 
                      FontSize="24" FontWeight="SemiBold" 
                      Foreground="White" TextAlignment="Center" 
                      Margin="0,0,0,10"/>

            <!-- Version Info -->
            <TextBlock x:Name="VersionText" Text="Version 1.1.6 is now available" 
                      FontSize="14" Foreground="#B5BAC1" 
                      TextAlignment="Center" Margin="0,0,0,20"/>

            <!-- Release Notes -->
            <Border Background="#2B2D31" CornerRadius="8" Padding="15" 
                   Margin="0,0,0,20">
                <StackPanel>
                    <TextBlock Text="What's New:" FontSize="12" 
                              FontWeight="SemiBold" Foreground="White" 
                              Margin="0,0,0,8"/>
                    <ScrollViewer MaxHeight="100" VerticalScrollBarVisibility="Auto">
                        <TextBlock x:Name="ReleaseNotesText" 
                                  Text="Bug fixes and improvements" 
                                  FontSize="12" Foreground="#B5BAC1" 
                                  TextWrapping="Wrap"/>
                    </ScrollViewer>
                </StackPanel>
            </Border>

            <!-- Progress Bar (Hidden by default) -->
            <StackPanel x:Name="ProgressPanel" Visibility="Collapsed" Margin="0,0,0,10">
                <TextBlock x:Name="ProgressText" Text="Downloading update..." 
                          FontSize="12" Foreground="#B5BAC1" 
                          Margin="0,0,0,5"/>
                <ProgressBar x:Name="ProgressBar" Height="6" 
                            Background="#2B2D31" Foreground="#00B0F4" 
                            Minimum="0" Maximum="100" Value="0"/>
            </StackPanel>

        </StackPanel>

        <!-- Buttons -->
        <Grid Grid.Row="2" Background="#2B2D31" Height="70">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" 
                       VerticalAlignment="Center">
                <ui:Button x:Name="UpdateButton" Content="Update Now" 
                          Appearance="Primary" 
                          Width="140" Height="40" Margin="0,0,10,0"
                          Click="UpdateButton_Click"/>
                <ui:Button x:Name="LaterButton" Content="Later" 
                          Appearance="Secondary" 
                          Width="140" Height="40"
                          Click="LaterButton_Click"/>
            </StackPanel>
        </Grid>
    </Grid>
</ui:FluentWindow>
