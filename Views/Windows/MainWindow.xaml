<Window
    x:Class="Cordex.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    xmlns:cef="clr-namespace:CefSharp.Wpf;assembly=CefSharp.Wpf"
    Title="Cordex"
    Icon="pack://application:,,,/Assets/app.ico"
    Width="1100"
    Height="700"
    MinWidth="800"
    MinHeight="500"
    WindowStyle="None"
    AllowsTransparency="False"
    ResizeMode="CanResize"
    WindowStartupLocation="CenterScreen"
    ShowInTaskbar="True"
    Background="#1e1f22">

    <WindowChrome.WindowChrome>
        <WindowChrome
            CaptionHeight="36"
            GlassFrameThickness="0"
            ResizeBorderThickness="0"
            UseAeroCaptionButtons="False"
            CornerRadius="8"/>
    </WindowChrome.WindowChrome>

    <Window.Resources>

        <Style x:Key="MacBtn" TargetType="Button">
            <Setter Property="Width"           Value="14"/>
            <Setter Property="Height"          Value="14"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="WindowChrome.IsHitTestVisibleInChrome" Value="True"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Ellipse x:Name="Circle" Fill="{TemplateBinding Background}">
                            <Ellipse.Effect>
                                <DropShadowEffect Color="Black" Opacity="0.4"
                                                  BlurRadius="4" ShadowDepth="1"/>
                            </Ellipse.Effect>
                        </Ellipse>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Circle" Property="Opacity" Value="0.72"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Circle" Property="Opacity" Value="0.45"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="GearBtn" TargetType="Button">
            <Setter Property="Width"           Value="30"/>
            <Setter Property="Height"          Value="30"/>
            <Setter Property="Background"      Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="WindowChrome.IsHitTestVisibleInChrome" Value="True"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bg" Background="{TemplateBinding Background}" CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bg" Property="Background" Value="#2B2D31"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bg" Property="Background" Value="#1E1F22"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </Window.Resources>

    <Border x:Name="WindowBorder" BorderBrush="#3A3C40" BorderThickness="1" CornerRadius="8">
        <Grid>

            <cef:ChromiumWebBrowser x:Name="Browser" Address="about:blank"/>

            <Grid Height="36" VerticalAlignment="Top">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="80"/>
                </Grid.ColumnDefinitions>

                <StackPanel
                    Grid.Column="0"
                    Orientation="Horizontal"
                    VerticalAlignment="Center"
                    Margin="14,-3,0,0">

                    <Button
                        Style="{StaticResource MacBtn}"
                        Background="#FF5F57"
                        ToolTip="Close to tray"
                        Margin="0,0,9,0"
                        Click="BtnClose_Click"/>

                    <Button
                        Style="{StaticResource MacBtn}"
                        Background="#28C840"
                        ToolTip="Maximize"
                        Margin="0,0,9,0"
                        Click="BtnMaximize_Click"/>

                    <Button
                        Style="{StaticResource MacBtn}"
                        Background="#FEBC2E"
                        ToolTip="Minimize"
                        Margin="0,0,16,0"
                        Click="BtnMinimize_Click"/>

                    <Rectangle
                        Width="1" Height="18"
                        Fill="#3A3C40"
                        VerticalAlignment="Center"
                        Margin="0,0,8,0"/>

                    <Button
                        Style="{StaticResource GearBtn}"
                        ToolTip="Cordex Settings"
                        Click="BtnSettings_Click">
                        <ui:SymbolIcon Symbol="Settings24" FontSize="18" Foreground="#96989D"/>
                    </Button>

                </StackPanel>

                <Border Grid.Column="1" Background="Transparent"/>

            </Grid>

        </Grid>
    </Border>

</Window>
