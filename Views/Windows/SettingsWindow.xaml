<ui:FluentWindow
    x:Class="Cordex.SettingsWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    Title="Cordex Settings"
    Width="900"
    Height="650"
    ResizeMode="NoResize"
    WindowStartupLocation="CenterOwner"
    Background="#1e1f22">

    <Window.Resources>

        <Style x:Key="ResetBtn" TargetType="Button">
            <Setter Property="Width"           Value="54"/>
            <Setter Property="Height"          Value="26"/>
            <Setter Property="Background"      Value="#313338"/>
            <Setter Property="Foreground"      Value="#80848E"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontSize"        Value="11"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bg" Background="{TemplateBinding Background}" CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bg" Property="Background" Value="#3C3F45"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SaveBtn" TargetType="Button">
            <Setter Property="Height"          Value="36"/>
            <Setter Property="Background"      Value="#5865F2"/>
            <Setter Property="Foreground"      Value="White"/>
            <Setter Property="FontWeight"      Value="SemiBold"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bg" Background="{TemplateBinding Background}" CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"
                                              Margin="18,0"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bg" Property="Background" Value="#4752C4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="CancelBtn" TargetType="Button">
            <Setter Property="Height"          Value="36"/>
            <Setter Property="Background"      Value="Transparent"/>
            <Setter Property="Foreground"      Value="#80848E"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bg" Background="{TemplateBinding Background}" CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"
                                              Margin="18,0"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Foreground" Value="White"/>
                                <Setter TargetName="Bg" Property="Background" Value="#2B2D31"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- ── Sidebar ── -->
        <Border Grid.Column="0" Background="#1A1B1E">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel Margin="8,16,8,16">

                    <TextBlock Text="USER SETTINGS"
                               FontSize="10" FontWeight="Bold"
                               Foreground="#4E5058"
                               Margin="10,0,0,8"/>

                    <Button x:Name="NavGeneral"
                            Content="General"
                            Tag="General"
                            HorizontalContentAlignment="Left"
                            Padding="10,8"
                            Background="#404249"
                            Foreground="White"
                            BorderThickness="0"
                            Cursor="Hand"
                            FontSize="13"
                            Margin="0,1"
                            Click="NavButton_Click">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="Bg" Background="{TemplateBinding Background}" CornerRadius="4">
                                    <ContentPresenter Margin="10,6" HorizontalAlignment="Left"
                                                      VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="Bg" Property="Background" Value="#404249"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>

                    <Button x:Name="NavVoiceAudio"
                            Content="Voice &amp; Audio"
                            Tag="VoiceAudio"
                            HorizontalContentAlignment="Left"
                            Padding="10,8"
                            Background="Transparent"
                            Foreground="#96989D"
                            BorderThickness="0"
                            Cursor="Hand"
                            FontSize="13"
                            Margin="0,1"
                            Click="NavButton_Click">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="Bg" Background="{TemplateBinding Background}" CornerRadius="4">
                                    <ContentPresenter Margin="10,6" HorizontalAlignment="Left"
                                                      VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="Bg" Property="Background" Value="#2E2F34"/>
                                        <Setter Property="Foreground" Value="White"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>

                    <Button x:Name="NavNotifications"
                            Content="Notifications"
                            Tag="Notifications"
                            HorizontalContentAlignment="Left"
                            Padding="10,8"
                            Background="Transparent"
                            Foreground="#96989D"
                            BorderThickness="0"
                            Cursor="Hand"
                            FontSize="13"
                            Margin="0,1"
                            Click="NavButton_Click">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="Bg" Background="{TemplateBinding Background}" CornerRadius="4">
                                    <ContentPresenter Margin="10,6" HorizontalAlignment="Left"
                                                      VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="Bg" Property="Background" Value="#2E2F34"/>
                                        <Setter Property="Foreground" Value="White"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>

                    <Button x:Name="NavPerformance"
                            Content="Performance"
                            Tag="Performance"
                            HorizontalContentAlignment="Left"
                            Padding="10,8"
                            Background="Transparent"
                            Foreground="#96989D"
                            BorderThickness="0"
                            Cursor="Hand"
                            FontSize="13"
                            Margin="0,1"
                            Click="NavButton_Click">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="Bg" Background="{TemplateBinding Background}" CornerRadius="4">
                                    <ContentPresenter Margin="10,6" HorizontalAlignment="Left"
                                                      VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="Bg" Property="Background" Value="#2E2F34"/>
                                        <Setter Property="Foreground" Value="White"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>

                    <Button x:Name="NavKeybinds"
                            Content="Keybinds"
                            Tag="Keybinds"
                            HorizontalContentAlignment="Left"
                            Padding="10,8"
                            Background="Transparent"
                            Foreground="#96989D"
                            BorderThickness="0"
                            Cursor="Hand"
                            FontSize="13"
                            Margin="0,1"
                            Click="NavButton_Click">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="Bg" Background="{TemplateBinding Background}" CornerRadius="4">
                                    <ContentPresenter Margin="10,6" HorizontalAlignment="Left"
                                                      VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="Bg" Property="Background" Value="#2E2F34"/>
                                        <Setter Property="Foreground" Value="White"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>

                    <Rectangle Height="1" Fill="#2B2D31" Margin="10,12"/>

                    <TextBlock Text="APP SETTINGS"
                               FontSize="10" FontWeight="Bold"
                               Foreground="#4E5058"
                               Margin="10,4,0,8"/>

                    <Button x:Name="NavAbout"
                            Content="About"
                            Tag="About"
                            HorizontalContentAlignment="Left"
                            Padding="10,8"
                            Background="Transparent"
                            Foreground="#96989D"
                            BorderThickness="0"
                            Cursor="Hand"
                            FontSize="13"
                            Margin="0,1"
                            Click="NavButton_Click">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="Bg" Background="{TemplateBinding Background}" CornerRadius="4">
                                    <ContentPresenter Margin="10,6" HorizontalAlignment="Left"
                                                      VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="Bg" Property="Background" Value="#2E2F34"/>
                                        <Setter Property="Foreground" Value="White"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>

                </StackPanel>
            </ScrollViewer>
        </Border>

        <!-- ── Content Area ── -->
        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto" Margin="24,24,24,0">
                <StackPanel>

                    <!-- ── General Page ── -->
                    <StackPanel x:Name="PageGeneral">
                        <TextBlock Text="General"
                                   FontSize="20" FontWeight="SemiBold"
                                   Foreground="White" Margin="0,0,0,4"/>
                        <TextBlock Text="Configure general application settings."
                                   FontSize="12" Foreground="#80848E"
                                   TextWrapping="Wrap" Margin="0,0,0,20"/>

                        <!-- Start with Windows -->
                        <Border Background="#2B2D31" CornerRadius="8" Padding="16,14" Margin="0,0,0,8">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                    <TextBlock Text="Start with Windows"
                                               Foreground="White" FontSize="14"/>
                                    <TextBlock Text="Launch Cordex automatically when Windows starts"
                                               Foreground="#80848E" FontSize="11"
                                               Margin="0,2,0,0"/>
                                </StackPanel>
                                <ui:ToggleSwitch x:Name="ToggleStartWithWindows" Grid.Column="1"
                                                 VerticalAlignment="Center" Margin="12,0,0,0"/>
                            </Grid>
                        </Border>

                        <!-- Confirm on Exit -->
                        <Border Background="#2B2D31" CornerRadius="8" Padding="16,14" Margin="0,0,0,8">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                    <TextBlock Text="Confirm on Exit"
                                               Foreground="White" FontSize="14"/>
                                    <TextBlock Text="Show confirmation dialog when exiting the application"
                                               Foreground="#80848E" FontSize="11"
                                               Margin="0,2,0,0"/>
                                </StackPanel>
                                <ui:ToggleSwitch x:Name="ToggleConfirmExit" Grid.Column="1"
                                                 VerticalAlignment="Center" Margin="12,0,0,0"/>
                            </Grid>
                        </Border>

                        <!-- Section divider: Window Behaviour -->
                        <Rectangle Height="1" Fill="#2B2D31" Margin="0,12,0,12"/>
                        <TextBlock Text="WINDOW BEHAVIOUR"
                                   FontSize="10" FontWeight="Bold"
                                   Foreground="#4E5058"
                                   Margin="0,0,0,12"/>

                        <!-- Close to Tray -->
                        <Border Background="#2B2D31" CornerRadius="8" Padding="16,14" Margin="0,0,0,8">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                    <TextBlock Text="Close to System Tray"
                                               Foreground="White" FontSize="14"/>
                                    <TextBlock Text="When closing the window, minimize to tray instead of exiting"
                                               Foreground="#80848E" FontSize="11"
                                               TextWrapping="Wrap" Margin="0,2,0,0"/>
                                </StackPanel>
                                <ui:ToggleSwitch x:Name="ToggleCloseToTray" Grid.Column="1"
                                                 VerticalAlignment="Center" Margin="12,0,0,0"/>
                            </Grid>
                        </Border>

                        <!-- Minimize to Tray -->
                        <Border Background="#2B2D31" CornerRadius="8" Padding="16,14" Margin="0,0,0,8">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                    <TextBlock Text="Minimize to System Tray"
                                               Foreground="White" FontSize="14"/>
                                    <TextBlock Text="Hide window in system tray when minimized"
                                               Foreground="#80848E" FontSize="11"
                                               Margin="0,2,0,0"/>
                                </StackPanel>
                                <ui:ToggleSwitch x:Name="ToggleMinimizeToTray" Grid.Column="1"
                                                 VerticalAlignment="Center" Margin="12,0,0,0"/>
                            </Grid>
                        </Border>

                        <!-- Start Minimized -->
                        <Border Background="#2B2D31" CornerRadius="8" Padding="16,14" Margin="0,0,0,8">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                    <TextBlock Text="Start Minimized"
                                               Foreground="White" FontSize="14"/>
                                    <TextBlock Text="Launch Cordex minimized to system tray"
                                               Foreground="#80848E" FontSize="11"
                                               Margin="0,2,0,0"/>
                                </StackPanel>
                                <ui:ToggleSwitch x:Name="ToggleStartMinimized" Grid.Column="1"
                                                 VerticalAlignment="Center" Margin="12,0,0,0"/>
                            </Grid>
                        </Border>

                        <!-- Section divider: Discord API Blocking -->
                        <Rectangle Height="1" Fill="#2B2D31" Margin="0,12,0,12"/>
                        <TextBlock Text="DISCORD API BLOCKING"
                                   FontSize="10" FontWeight="Bold"
                                   Foreground="#4E5058"
                                   Margin="0,0,0,4"/>
                        <TextBlock Text="Block Discord API requests and scripts to harden the privacy."
                                   FontSize="12" Foreground="#80848E"
                                   TextWrapping="Wrap" Margin="0,0,0,12"/>

                        <Border Background="#2B2D31" CornerRadius="8" Padding="16,16" Margin="0,0,0,8">
                            <StackPanel>
                                <CheckBox x:Name="ToggleBlockFingerprinting" Margin="0,0,0,16">
                                    <TextBlock Foreground="#DCDDDE" FontSize="13">
                                        <Run Text="Block known fingerprinting methods ("/>
                                        <Run Text=" api.js " Background="#1E1F22" Foreground="#A3A6AA"/>
                                        <Run Text=" and "/>
                                        <Run Text=" cdn-cgi " Background="#1E1F22" Foreground="#A3A6AA"/>
                                        <Run Text=")."/>
                                    </TextBlock>
                                </CheckBox>

                                <CheckBox x:Name="ToggleBlockTelemetry" Margin="0,0,0,16">
                                    <TextBlock Foreground="#DCDDDE" FontSize="13">
                                        <Run Text="Block known telemetry endpoints ("/>
                                        <Run Text=" /science " Background="#1E1F22" Foreground="#A3A6AA"/>
                                        <Run Text=" and "/>
                                        <Run Text=" /tracing " Background="#1E1F22" Foreground="#A3A6AA"/>
                                        <Run Text=")."/>
                                    </TextBlock>
                                </CheckBox>

                                <CheckBox x:Name="ToggleBlockSentry" Margin="0,0,0,16">
                                    <TextBlock Foreground="#DCDDDE" FontSize="13">
                                        <Run Text="Block loading Sentry in Discord"/>
                                    </TextBlock>
                                </CheckBox>

                                <CheckBox x:Name="ToggleBlockTypingIndicator" Margin="0,0,0,16">
                                    <TextBlock Foreground="#DCDDDE" FontSize="13">
                                        <Run Text="Block typing indicator ("/>
                                        <Run Text=" /typing " Background="#1E1F22" Foreground="#A3A6AA"/>
                                        <Run Text=")."/>
                                    </TextBlock>
                                </CheckBox>

                                <CheckBox x:Name="ToggleBlockAnimatedAssets" Margin="0,0,0,16">
                                    <TextBlock Foreground="#DCDDDE" FontSize="13">
                                        <Run Text="Block animated assets ("/>
                                        <Run Text=" .gif " Background="#1E1F22" Foreground="#A3A6AA"/>
                                        <Run Text=" and "/>
                                        <Run Text=" /a_ " Background="#1E1F22" Foreground="#A3A6AA"/>
                                        <Run Text=")."/>
                                    </TextBlock>
                                </CheckBox>

                                <CheckBox x:Name="ToggleBlockCrashReports" Margin="0,0,0,0">
                                    <TextBlock Foreground="#DCDDDE" FontSize="13">
                                        <Run Text="Block crash reports ("/>
                                        <Run Text=" errors.discord.com " Background="#1E1F22" Foreground="#A3A6AA"/>
                                        <Run Text=")."/>
                                    </TextBlock>
                                </CheckBox>
                            </StackPanel>
                        </Border>

                        <!-- Section divider: Performance Blocking -->
                        <Rectangle Height="1" Fill="#2B2D31" Margin="0,12,0,12"/>
                        <TextBlock Text="PERFORMANCE BLOCKING"
                                   FontSize="10" FontWeight="Bold"
                                   Foreground="#4E5058"
                                   Margin="0,0,0,4"/>
                        <TextBlock Text="Block background API calls that increase load times and consume bandwidth."
                                   FontSize="12" Foreground="#80848E"
                                   TextWrapping="Wrap" Margin="0,0,0,12"/>

                        <Border Background="#2B2D31" CornerRadius="8" Padding="16,16" Margin="0,0,0,8">
                            <StackPanel>
                                <CheckBox x:Name="ToggleBlockExperiments" Margin="0,0,0,16">
                                    <TextBlock Foreground="#DCDDDE" FontSize="13">
                                        <Run Text="Block A/B experiments ("/>
                                        <Run Text=" /experiments " Background="#1E1F22" Foreground="#A3A6AA"/>
                                        <Run Text=") — saves ~400 KB startup JSON."/>
                                    </TextBlock>
                                </CheckBox>

                                <CheckBox x:Name="ToggleBlockMarketing" Margin="0,0,0,16">
                                    <TextBlock Foreground="#DCDDDE" FontSize="13">
                                        <Run Text="Block quests &amp; marketing ("/>
                                        <Run Text=" /quests/ " Background="#1E1F22" Foreground="#A3A6AA"/>
                                        <Run Text=", "/>
                                        <Run Text=" /promotions " Background="#1E1F22" Foreground="#A3A6AA"/>
                                        <Run Text=", "/>
                                        <Run Text=" /referrals/ " Background="#1E1F22" Foreground="#A3A6AA"/>
                                        <Run Text=")."/>
                                    </TextBlock>
                                </CheckBox>

                                <CheckBox x:Name="ToggleBlockDetectableGames" Margin="0,0,0,16">
                                    <TextBlock Foreground="#DCDDDE" FontSize="13">
                                        <Run Text="Block game library download ("/>
                                        <Run Text=" /games/detectable " Background="#1E1F22" Foreground="#A3A6AA"/>
                                        <Run Text=") — saves ~300 KB."/>
                                    </TextBlock>
                                </CheckBox>

                                <CheckBox x:Name="ToggleBlockExternalImages" Margin="0,0,0,16">
                                    <TextBlock Foreground="#DCDDDE" FontSize="13">
                                        <Run Text="Block external image proxy ("/>
                                        <Run Text=" images-ext-*.discordapp.net " Background="#1E1F22" Foreground="#A3A6AA"/>
                                        <Run Text=") — disables link embeds."/>
                                    </TextBlock>
                                </CheckBox>

                                <CheckBox x:Name="ToggleBlockStatusPolling" Margin="0,0,0,16">
                                    <TextBlock Foreground="#DCDDDE" FontSize="13">
                                        <Run Text="Block status page polling ("/>
                                        <Run Text=" status.discord.com " Background="#1E1F22" Foreground="#A3A6AA"/>
                                        <Run Text=")."/>
                                    </TextBlock>
                                </CheckBox>

                                <CheckBox x:Name="ToggleBlockContentInventory" Margin="0,0,0,0">
                                    <TextBlock Foreground="#DCDDDE" FontSize="13">
                                        <Run Text="Block content inventory ("/>
                                        <Run Text=" /content-inventory/ " Background="#1E1F22" Foreground="#A3A6AA"/>
                                        <Run Text=") — disables Activity tab feed."/>
                                    </TextBlock>
                                </CheckBox>
                            </StackPanel>
                        </Border>

                    </StackPanel>


                    <!-- ── Voice & Audio Page ── -->
                    <StackPanel x:Name="PageVoiceAudio" Visibility="Collapsed">
                        <TextBlock Text="Voice &amp; Audio"
                                   FontSize="20" FontWeight="SemiBold"
                                   Foreground="White" Margin="0,0,0,4"/>
                        <TextBlock Text="Configure voice and audio settings."
                                   FontSize="12" Foreground="#80848E"
                                   TextWrapping="Wrap" Margin="0,0,0,20"/>

                        <!-- Show Voice Activity -->
                        <Border Background="#2B2D31" CornerRadius="8" Padding="16,14" Margin="0,0,0,8">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                    <TextBlock Text="Show Voice Activity"
                                               Foreground="White" FontSize="14"/>
                                    <TextBlock Text="Display talking indicator in system tray"
                                               Foreground="#80848E" FontSize="11"
                                               Margin="0,2,0,0"/>
                                </StackPanel>
                                <ui:ToggleSwitch x:Name="ToggleShowVoiceActivity" Grid.Column="1"
                                                 VerticalAlignment="Center" Margin="12,0,0,0"/>
                            </Grid>
                        </Border>

                        <!-- Automatically Mute -->
                        <Border Background="#2B2D31" CornerRadius="8" Padding="16,14" Margin="0,0,0,8">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                    <TextBlock Text="Automatically Mute on Join"
                                               Foreground="White" FontSize="14"/>
                                    <TextBlock Text="Mute microphone when joining voice channels"
                                               Foreground="#80848E" FontSize="11"
                                               Margin="0,2,0,0"/>
                                </StackPanel>
                                <ui:ToggleSwitch x:Name="ToggleAutoMute" Grid.Column="1"
                                                 VerticalAlignment="Center" Margin="12,0,0,0"/>
                            </Grid>
                        </Border>

                        <!-- Voice Activity Threshold -->
                        <Border Background="#2B2D31" CornerRadius="8" Padding="16,14" Margin="0,0,0,8">
                            <StackPanel>
                                <TextBlock Text="Voice Activity Threshold"
                                           Foreground="White" FontSize="14" Margin="0,0,0,8"/>
                                <TextBlock Text="Adjust the sensitivity for voice activity detection"
                                           Foreground="#80848E" FontSize="11" Margin="0,0,0,12"/>
                                <Slider x:Name="SliderVoiceThreshold"
                                        Minimum="0" Maximum="100"
                                        TickFrequency="10"
                                        IsSnapToTickEnabled="True"
                                        Foreground="#5865F2"/>
                                <TextBlock x:Name="TxtVoiceThreshold" Text="50%"
                                           Foreground="#B5BAC1" FontSize="12"
                                           HorizontalAlignment="Center" Margin="0,4,0,0"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>

                    <!-- ── Notifications Page ── -->
                    <StackPanel x:Name="PageNotifications" Visibility="Collapsed">
                        <TextBlock Text="Notifications"
                                   FontSize="20" FontWeight="SemiBold"
                                   Foreground="White" Margin="0,0,0,4"/>
                        <TextBlock Text="Manage notification preferences."
                                   FontSize="12" Foreground="#80848E"
                                   TextWrapping="Wrap" Margin="0,0,0,20"/>

                        <!-- Show Notifications -->
                        <Border Background="#2B2D31" CornerRadius="8" Padding="16,14" Margin="0,0,0,8">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                    <TextBlock Text="Enable Notifications"
                                               Foreground="White" FontSize="14"/>
                                    <TextBlock Text="Show desktop notifications for messages and events"
                                               Foreground="#80848E" FontSize="11"
                                               Margin="0,2,0,0"/>
                                </StackPanel>
                                <ui:ToggleSwitch x:Name="ToggleShowNotifications" Grid.Column="1"
                                                 VerticalAlignment="Center" Margin="12,0,0,0"/>
                            </Grid>
                        </Border>

                        <!-- Notification Sounds -->
                        <Border Background="#2B2D31" CornerRadius="8" Padding="16,14" Margin="0,0,0,8">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                    <TextBlock Text="Notification Sounds"
                                               Foreground="White" FontSize="14"/>
                                    <TextBlock Text="Play sounds for notifications"
                                               Foreground="#80848E" FontSize="11"
                                               Margin="0,2,0,0"/>
                                </StackPanel>
                                <ui:ToggleSwitch x:Name="ToggleNotificationSounds" Grid.Column="1"
                                                 VerticalAlignment="Center" Margin="12,0,0,0"/>
                            </Grid>
                        </Border>
                    </StackPanel>

                    <!-- ── Performance Page ── -->
                    <StackPanel x:Name="PagePerformance" Visibility="Collapsed">
                        <TextBlock Text="Performance"
                                   FontSize="20" FontWeight="SemiBold"
                                   Foreground="White" Margin="0,0,0,4"/>
                        <TextBlock Text="Optimize and limit resource usage for better performance."
                                   FontSize="12" Foreground="#80848E"
                                   TextWrapping="Wrap" Margin="0,0,0,20"/>

                        <!-- Hardware Acceleration -->
                        <Border Background="#2B2D31" CornerRadius="8" Padding="16,14" Margin="0,0,0,8">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                    <TextBlock Text="Hardware Acceleration"
                                               Foreground="White" FontSize="14"/>
                                    <TextBlock Text="Uses GPU to improve performance. Requires restart. (Disabled by default for stability)"
                                               Foreground="#80848E" FontSize="11"
                                               TextWrapping="Wrap" Margin="0,2,0,0"/>
                                </StackPanel>
                                <ui:ToggleSwitch x:Name="ToggleHardwareAccel" Grid.Column="1"
                                                 VerticalAlignment="Center" Margin="12,0,0,0"/>
                            </Grid>
                        </Border>

                        <!-- Reduced Motion -->
                        <Border Background="#2B2D31" CornerRadius="8" Padding="16,14" Margin="0,0,0,8">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                    <TextBlock Text="Reduced Motion"
                                               Foreground="White" FontSize="14"/>
                                    <TextBlock Text="Reduces animations and motion effects"
                                               Foreground="#80848E" FontSize="11"
                                               Margin="0,2,0,0"/>
                                </StackPanel>
                                <ui:ToggleSwitch x:Name="ToggleReducedMotion" Grid.Column="1"
                                                 VerticalAlignment="Center" Margin="12,0,0,0"/>
                            </Grid>
                        </Border>

                        <!-- Enable Performance Limits -->
                        <Border Background="#2B2D31" CornerRadius="8" Padding="16,14" Margin="0,0,0,8">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                    <TextBlock Text="Enable Performance Limits"
                                               Foreground="White" FontSize="14"/>
                                    <TextBlock Text="Apply CPU and RAM limits to reduce resource usage"
                                               Foreground="#80848E" FontSize="11"
                                               Margin="0,2,0,0"/>
                                </StackPanel>
                                <ui:ToggleSwitch x:Name="TogglePerformanceLimits" Grid.Column="1"
                                                 VerticalAlignment="Center" Margin="12,0,0,0"
                                                 Checked="TogglePerformanceLimits_Changed"
                                                 Unchecked="TogglePerformanceLimits_Changed"/>
                            </Grid>
                        </Border>

                        <!-- CPU Core Limiter -->
                        <Border x:Name="BorderCpuCores" Background="#2B2D31" CornerRadius="8" Padding="16,14" Margin="0,0,0,8" IsEnabled="False">
                            <StackPanel>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="CPU Core Limit"
                                                   Foreground="White" FontSize="14"/>
                                        <TextBlock Text="Maximum number of CPU cores the app can use"
                                                   Foreground="#80848E" FontSize="11" Margin="0,2,0,0"/>
                                    </StackPanel>
                                    <TextBlock x:Name="TxtCpuCores" Grid.Column="1"
                                               Foreground="#5865F2" FontSize="14" FontWeight="SemiBold"
                                               VerticalAlignment="Center"/>
                                </Grid>
                                <Slider x:Name="SliderCpuCores"
                                        Minimum="1"
                                        TickFrequency="1"
                                        IsSnapToTickEnabled="True"
                                        Foreground="#5865F2"
                                        Margin="0,12,0,0"
                                        ValueChanged="SliderCpuCores_ValueChanged"/>
                            </StackPanel>
                        </Border>

                        <!-- RAM Limiter -->
                        <Border x:Name="BorderRamLimit" Background="#2B2D31" CornerRadius="8" Padding="16,14" Margin="0,0,0,8" IsEnabled="False">
                            <StackPanel>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="RAM Limit"
                                                   Foreground="White" FontSize="14"/>
                                        <TextBlock Text="Maximum RAM usage in MB (minimum 100 MB)"
                                                   Foreground="#80848E" FontSize="11" Margin="0,2,0,0"/>
                                    </StackPanel>
                                    <TextBlock x:Name="TxtRamLimit" Grid.Column="1"
                                               Foreground="#5865F2" FontSize="14" FontWeight="SemiBold"
                                               VerticalAlignment="Center"/>
                                </Grid>
                                <Slider x:Name="SliderRamLimit"
                                        Minimum="100" Maximum="2048" Value="200"
                                        TickFrequency="50"
                                        IsSnapToTickEnabled="True"
                                        Foreground="#5865F2"
                                        Margin="0,12,0,0"
                                        ValueChanged="SliderRamLimit_ValueChanged"/>
                            </StackPanel>
                        </Border>



                        <!-- CPU Affinity -->
                        <Border x:Name="BorderCpuAffinity" Background="#2B2D31" CornerRadius="8" Padding="16,14" Margin="0,0,0,8" IsEnabled="False">
                            <StackPanel>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="CPU Affinity"
                                                   Foreground="White" FontSize="14"/>
                                        <TextBlock Text="Select which CPU cores the app can use"
                                                   Foreground="#80848E" FontSize="11" Margin="0,2,0,0"/>
                                    </StackPanel>
                                    <ui:Button x:Name="BtnExpandCpuAffinity" Grid.Column="1"
                                              Content="▼"
                                              Appearance="Secondary"
                                              Width="36"
                                              VerticalAlignment="Center"
                                              Click="BtnExpandCpuAffinity_Click"/>
                                </Grid>
                                <StackPanel x:Name="PanelCpuCores" Visibility="Collapsed" Margin="0,12,0,0">
                                    <TextBlock Text="Select CPU Cores:"
                                               Foreground="#B5BAC1" FontSize="12" Margin="0,0,0,8"/>
                                    <ScrollViewer MaxHeight="200" VerticalScrollBarVisibility="Auto">
                                        <WrapPanel x:Name="WrapPanelCpuCores" Orientation="Horizontal"/>
                                    </ScrollViewer>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <!-- Limit GPU Usage -->
                        <Border x:Name="BorderGpuLimit" Background="#2B2D31" CornerRadius="8" Padding="16,14" Margin="0,0,0,8" IsEnabled="False">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                    <TextBlock Text="Limit GPU Usage"
                                               Foreground="White" FontSize="14"/>
                                    <TextBlock Text="Reduce GPU rendering quality to save resources"
                                               Foreground="#80848E" FontSize="11"
                                               Margin="0,2,0,0"/>
                                </StackPanel>
                                <ui:ToggleSwitch x:Name="ToggleLimitGpu" Grid.Column="1"
                                                 VerticalAlignment="Center" Margin="12,0,0,0"/>
                            </Grid>
                        </Border>

                        <!-- Reduce Background Activity -->
                        <Border x:Name="BorderBackgroundActivity" Background="#2B2D31" CornerRadius="8" Padding="16,14" Margin="0,0,0,8" IsEnabled="False">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                    <TextBlock Text="Reduce Background Activity"
                                               Foreground="White" FontSize="14"/>
                                    <TextBlock Text="Lower activity when app is minimized or in background"
                                               Foreground="#80848E" FontSize="11"
                                               Margin="0,2,0,0"/>
                                </StackPanel>
                                <ui:ToggleSwitch x:Name="ToggleReduceBackground" Grid.Column="1"
                                                 VerticalAlignment="Center" Margin="12,0,0,0"/>
                            </Grid>
                        </Border>
                    </StackPanel>

                    <!-- ── Keybinds Page ── -->
                    <StackPanel x:Name="PageKeybinds" Visibility="Collapsed">
                        <TextBlock Text="Keybinds"
                                   FontSize="20" FontWeight="SemiBold"
                                   Foreground="White" Margin="0,0,0,4"/>
                        <TextBlock Text="Customize your global hotkeys. Click a field then press your desired key combination."
                                   FontSize="12" Foreground="#80848E"
                                   TextWrapping="Wrap" Margin="0,0,0,20"/>

                        <!-- Mute Row -->
                        <Border Background="#2B2D31" CornerRadius="8" Padding="16,14" Margin="0,0,0,8">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="150"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                    <TextBlock Text="Toggle Mute" Foreground="White" FontSize="14"/>
                                    <TextBlock Text="Mute or unmute your microphone" Foreground="#80848E" FontSize="11" Margin="0,2,0,0"/>
                                </StackPanel>
                                <Border Grid.Column="1" Background="#1E1F22" CornerRadius="6" Margin="12,0">
                                    <TextBox x:Name="TbMute" Background="Transparent" BorderThickness="0"
                                             Foreground="#00B0F4" FontSize="12" FontWeight="SemiBold"
                                             TextAlignment="Center" VerticalAlignment="Center"
                                             IsReadOnly="True" Cursor="Hand" Padding="8,7"
                                             PreviewMouseDown="KeybindBox_MouseDown"
                                             PreviewKeyDown="KeybindBox_KeyDown"
                                             LostFocus="KeybindBox_LostFocus" Tag="Mute"/>
                                </Border>
                                <Button Grid.Column="2" Content="Reset" Style="{StaticResource ResetBtn}" Click="ResetMute_Click"/>
                            </Grid>
                        </Border>

                        <!-- Deafen Row -->
                        <Border Background="#2B2D31" CornerRadius="8" Padding="16,14" Margin="0,0,0,8">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="150"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                    <TextBlock Text="Toggle Deafen" Foreground="White" FontSize="14"/>
                                    <TextBlock Text="Deafen or undeafen audio" Foreground="#80848E" FontSize="11" Margin="0,2,0,0"/>
                                </StackPanel>
                                <Border Grid.Column="1" Background="#1E1F22" CornerRadius="6" Margin="12,0">
                                    <TextBox x:Name="TbDeafen" Background="Transparent" BorderThickness="0"
                                             Foreground="#00B0F4" FontSize="12" FontWeight="SemiBold"
                                             TextAlignment="Center" VerticalAlignment="Center"
                                             IsReadOnly="True" Cursor="Hand" Padding="8,7"
                                             PreviewMouseDown="KeybindBox_MouseDown"
                                             PreviewKeyDown="KeybindBox_KeyDown"
                                             LostFocus="KeybindBox_LostFocus" Tag="Deafen"/>
                                </Border>
                                <Button Grid.Column="2" Content="Reset" Style="{StaticResource ResetBtn}" Click="ResetDeafen_Click"/>
                            </Grid>
                        </Border>

                        <!-- Focus Row -->
                        <Border Background="#2B2D31" CornerRadius="8" Padding="16,14" Margin="0,0,0,8">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="150"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                    <TextBlock Text="Focus Window" Foreground="White" FontSize="14"/>
                                    <TextBlock Text="Bring Cordex to the foreground" Foreground="#80848E" FontSize="11" Margin="0,2,0,0"/>
                                </StackPanel>
                                <Border Grid.Column="1" Background="#1E1F22" CornerRadius="6" Margin="12,0">
                                    <TextBox x:Name="TbFocus" Background="Transparent" BorderThickness="0"
                                             Foreground="#00B0F4" FontSize="12" FontWeight="SemiBold"
                                             TextAlignment="Center" VerticalAlignment="Center"
                                             IsReadOnly="True" Cursor="Hand" Padding="8,7"
                                             PreviewMouseDown="KeybindBox_MouseDown"
                                             PreviewKeyDown="KeybindBox_KeyDown"
                                             LostFocus="KeybindBox_LostFocus" Tag="Focus"/>
                                </Border>
                                <Button Grid.Column="2" Content="Reset" Style="{StaticResource ResetBtn}" Click="ResetFocus_Click"/>
                            </Grid>
                        </Border>

                        <!-- Push to Talk Row -->
                        <Border Background="#2B2D31" CornerRadius="8" Padding="16,14" Margin="0,0,0,8">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="150"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                    <TextBlock Text="Push to Talk" Foreground="White" FontSize="14"/>
                                    <TextBlock Text="Hold to transmit voice" Foreground="#80848E" FontSize="11" Margin="0,2,0,0"/>
                                </StackPanel>
                                <Border Grid.Column="1" Background="#1E1F22" CornerRadius="6" Margin="12,0">
                                    <TextBox x:Name="TbPushToTalk" Background="Transparent" BorderThickness="0"
                                             Foreground="#00B0F4" FontSize="12" FontWeight="SemiBold"
                                             TextAlignment="Center" VerticalAlignment="Center"
                                             IsReadOnly="True" Cursor="Hand" Padding="8,7"
                                             PreviewMouseDown="KeybindBox_MouseDown"
                                             PreviewKeyDown="KeybindBox_KeyDown"
                                             LostFocus="KeybindBox_LostFocus" Tag="PushToTalk"/>
                                </Border>
                                <Button Grid.Column="2" Content="Reset" Style="{StaticResource ResetBtn}" Click="ResetPushToTalk_Click"/>
                            </Grid>
                        </Border>

                        <!-- Push to Mute Row -->
                        <Border Background="#2B2D31" CornerRadius="8" Padding="16,14" Margin="0,0,0,8">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="150"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                    <TextBlock Text="Push to Mute" Foreground="White" FontSize="14"/>
                                    <TextBlock Text="Hold to temporarily mute" Foreground="#80848E" FontSize="11" Margin="0,2,0,0"/>
                                </StackPanel>
                                <Border Grid.Column="1" Background="#1E1F22" CornerRadius="6" Margin="12,0">
                                    <TextBox x:Name="TbPushToMute" Background="Transparent" BorderThickness="0"
                                             Foreground="#00B0F4" FontSize="12" FontWeight="SemiBold"
                                             TextAlignment="Center" VerticalAlignment="Center"
                                             IsReadOnly="True" Cursor="Hand" Padding="8,7"
                                             PreviewMouseDown="KeybindBox_MouseDown"
                                             PreviewKeyDown="KeybindBox_KeyDown"
                                             LostFocus="KeybindBox_LostFocus" Tag="PushToMute"/>
                                </Border>
                                <Button Grid.Column="2" Content="Reset" Style="{StaticResource ResetBtn}" Click="ResetPushToMute_Click"/>
                            </Grid>
                        </Border>
                    </StackPanel>

                    <!-- ── About Page ── -->
                    <StackPanel x:Name="PageAbout" Visibility="Collapsed">
                        <TextBlock Text="About Cordex"
                                   FontSize="20" FontWeight="SemiBold"
                                   Foreground="White" Margin="0,0,0,20"/>
                        <Border Background="#2B2D31" CornerRadius="8" Padding="20">
                            <StackPanel>
                                <TextBlock Text="Cordex" FontSize="22" FontWeight="Bold" Foreground="White"/>
                                <TextBlock x:Name="VersionTextBlock" Text="Version 1.1.3"
                                           Foreground="#80848E" FontSize="13" Margin="0,4,0,0"/>
                                <Rectangle Height="1" Fill="#3A3C40" Margin="0,16"/>
                                <TextBlock Text="A high-performance Discord client built with .NET 10, CefSharp Chromium, and WPF-UI."
                                           Foreground="#B5BAC1" FontSize="13" TextWrapping="Wrap"/>
                                <Rectangle Height="1" Fill="#3A3C40" Margin="0,16"/>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="Engine:"    Foreground="#80848E" FontSize="12" Width="80"/>
                                    <TextBlock Text="Chromium via CefSharp 120" Foreground="White" FontSize="12"/>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                                    <TextBlock Text="Framework:" Foreground="#80848E" FontSize="12" Width="80"/>
                                    <TextBlock Text=".NET 10 / WPF" Foreground="White" FontSize="12"/>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                                    <TextBlock Text="UI Library:" Foreground="#80848E" FontSize="12" Width="80"/>
                                    <TextBlock Text="WPF-UI (Wpf.Ui)" Foreground="White" FontSize="12"/>
                                </StackPanel>
                                <Rectangle Height="1" Fill="#3A3C40" Margin="0,16"/>
                                <ui:Button x:Name="CheckUpdateButton"
                                          Content="Check for Updates"
                                          Appearance="Primary"
                                          HorizontalAlignment="Left"
                                          Click="CheckUpdateButton_Click"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>

                </StackPanel>
            </ScrollViewer>

            <!-- Footer -->
            <Border Grid.Row="1"
                    BorderBrush="#2B2D31" BorderThickness="0,1,0,0"
                    Padding="24,14">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="Cancel" Width="90"
                            Style="{StaticResource CancelBtn}"
                            Margin="0,0,8,0"
                            Click="Cancel_Click"/>
                    <Button Content="Save Changes" Width="120"
                            Style="{StaticResource SaveBtn}"
                            Click="Save_Click"/>
                </StackPanel>
            </Border>

        </Grid>
    </Grid>
</ui:FluentWindow>
