<ui:FluentWindow
    x:Class="Nextcord.SettingsWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    Title="Nextcord Settings"
    Width="560"
    Height="520"
    ResizeMode="NoResize"
    WindowStartupLocation="CenterOwner"
    Background="#1e1f22">

    <Window.Resources>

        <Style x:Key="ResetBtn" TargetType="Button">
            <Setter Property="Width"           Value="54"/>
            <Setter Property="Height"          Value="26"/>
            <Setter Property="Background"      Value="#313338"/>
            <Setter Property="Foreground"      Value="#80848E"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontSize"        Value="11"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bg" Background="{TemplateBinding Background}" CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bg" Property="Background" Value="#3C3F45"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SaveBtn" TargetType="Button">
            <Setter Property="Height"          Value="36"/>
            <Setter Property="Background"      Value="#5865F2"/>
            <Setter Property="Foreground"      Value="White"/>
            <Setter Property="FontWeight"      Value="SemiBold"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bg" Background="{TemplateBinding Background}" CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"
                                              Margin="18,0"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bg" Property="Background" Value="#4752C4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="CancelBtn" TargetType="Button">
            <Setter Property="Height"          Value="36"/>
            <Setter Property="Background"      Value="Transparent"/>
            <Setter Property="Foreground"      Value="#80848E"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bg" Background="{TemplateBinding Background}" CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"
                                              Margin="18,0"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Foreground" Value="White"/>
                                <Setter TargetName="Bg" Property="Background" Value="#2B2D31"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <!-- Sidebar -->
            <ColumnDefinition Width="180"/>
            <!-- Content -->
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- ── Sidebar ── -->
        <Border Grid.Column="0" Background="#1A1B1E">
            <StackPanel Margin="8,16,8,16">

                <TextBlock Text="NEXTCORD"
                           FontSize="10" FontWeight="Bold"
                           Foreground="#4E5058"
                           Margin="10,0,0,8"/>

                <Button x:Name="NavKeybinds"
                        Content="Keybinds"
                        HorizontalContentAlignment="Left"
                        Padding="10,8"
                        Background="#404249"
                        Foreground="White"
                        BorderThickness="0"
                        Cursor="Hand"
                        FontSize="13"
                        Margin="0,1"
                        Click="NavKeybinds_Click">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="Bg" Background="{TemplateBinding Background}" CornerRadius="4">
                                <ContentPresenter Margin="10,6" HorizontalAlignment="Left"
                                                  VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Bg" Property="Background" Value="#404249"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>

                <Button x:Name="NavAbout"
                        Content="About"
                        HorizontalContentAlignment="Left"
                        Padding="10,8"
                        Background="Transparent"
                        Foreground="#96989D"
                        BorderThickness="0"
                        Cursor="Hand"
                        FontSize="13"
                        Margin="0,1"
                        Click="NavAbout_Click">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="Bg" Background="{TemplateBinding Background}" CornerRadius="4">
                                <ContentPresenter Margin="10,6" HorizontalAlignment="Left"
                                                  VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Bg" Property="Background" Value="#2E2F34"/>
                                    <Setter Property="Foreground" Value="White"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>

            </StackPanel>
        </Border>

        <!-- ── Content Area ── -->
        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto" Margin="24,24,24,0">
                <StackPanel>

                    <!-- ── Keybinds Page ── -->
                    <StackPanel x:Name="PageKeybinds">

                        <TextBlock Text="Keybinds"
                                   FontSize="20" FontWeight="SemiBold"
                                   Foreground="White" Margin="0,0,0,4"/>
                        <TextBlock Text="Customize your global hotkeys. Click a field then press your desired key combination."
                                   FontSize="12" Foreground="#80848E"
                                   TextWrapping="Wrap" Margin="0,0,0,20"/>

                        <!-- Mute Row -->
                        <Border Background="#2B2D31" CornerRadius="8"
                                Padding="16,14" Margin="0,0,0,8">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="150"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                    <TextBlock Text="Toggle Mute"
                                               Foreground="White" FontSize="14"/>
                                    <TextBlock Text="Mute or unmute your microphone"
                                               Foreground="#80848E" FontSize="11"
                                               Margin="0,2,0,0"/>
                                </StackPanel>
                                <Border Grid.Column="1" Background="#1E1F22"
                                        CornerRadius="6" Margin="12,0">
                                    <TextBox x:Name="TbMute"
                                             Background="Transparent"
                                             BorderThickness="0"
                                             Foreground="#00B0F4"
                                             FontSize="12" FontWeight="SemiBold"
                                             TextAlignment="Center"
                                             VerticalAlignment="Center"
                                             IsReadOnly="True" Cursor="Hand"
                                             Padding="8,7"
                                             PreviewMouseDown="KeybindBox_MouseDown"
                                             PreviewKeyDown="KeybindBox_KeyDown"
                                             LostFocus="KeybindBox_LostFocus"
                                             Tag="Mute"/>
                                </Border>
                                <Button Grid.Column="2" Content="Reset"
                                        Style="{StaticResource ResetBtn}"
                                        Click="ResetMute_Click"/>
                            </Grid>
                        </Border>

                        <!-- Deafen Row -->
                        <Border Background="#2B2D31" CornerRadius="8"
                                Padding="16,14" Margin="0,0,0,8">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="150"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                    <TextBlock Text="Toggle Deafen"
                                               Foreground="White" FontSize="14"/>
                                    <TextBlock Text="Deafen or undeafen audio"
                                               Foreground="#80848E" FontSize="11"
                                               Margin="0,2,0,0"/>
                                </StackPanel>
                                <Border Grid.Column="1" Background="#1E1F22"
                                        CornerRadius="6" Margin="12,0">
                                    <TextBox x:Name="TbDeafen"
                                             Background="Transparent"
                                             BorderThickness="0"
                                             Foreground="#00B0F4"
                                             FontSize="12" FontWeight="SemiBold"
                                             TextAlignment="Center"
                                             VerticalAlignment="Center"
                                             IsReadOnly="True" Cursor="Hand"
                                             Padding="8,7"
                                             PreviewMouseDown="KeybindBox_MouseDown"
                                             PreviewKeyDown="KeybindBox_KeyDown"
                                             LostFocus="KeybindBox_LostFocus"
                                             Tag="Deafen"/>
                                </Border>
                                <Button Grid.Column="2" Content="Reset"
                                        Style="{StaticResource ResetBtn}"
                                        Click="ResetDeafen_Click"/>
                            </Grid>
                        </Border>

                        <!-- Focus Row -->
                        <Border Background="#2B2D31" CornerRadius="8"
                                Padding="16,14" Margin="0,0,0,8">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="150"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                    <TextBlock Text="Focus Window"
                                               Foreground="White" FontSize="14"/>
                                    <TextBlock Text="Bring Nextcord to the foreground"
                                               Foreground="#80848E" FontSize="11"
                                               Margin="0,2,0,0"/>
                                </StackPanel>
                                <Border Grid.Column="1" Background="#1E1F22"
                                        CornerRadius="6" Margin="12,0">
                                    <TextBox x:Name="TbFocus"
                                             Background="Transparent"
                                             BorderThickness="0"
                                             Foreground="#00B0F4"
                                             FontSize="12" FontWeight="SemiBold"
                                             TextAlignment="Center"
                                             VerticalAlignment="Center"
                                             IsReadOnly="True" Cursor="Hand"
                                             Padding="8,7"
                                             PreviewMouseDown="KeybindBox_MouseDown"
                                             PreviewKeyDown="KeybindBox_KeyDown"
                                             LostFocus="KeybindBox_LostFocus"
                                             Tag="Focus"/>
                                </Border>
                                <Button Grid.Column="2" Content="Reset"
                                        Style="{StaticResource ResetBtn}"
                                        Click="ResetFocus_Click"/>
                            </Grid>
                        </Border>

                    </StackPanel>

                    <!-- ── About Page ── -->
                    <StackPanel x:Name="PageAbout" Visibility="Collapsed">

                        <TextBlock Text="About Nextcord"
                                   FontSize="20" FontWeight="SemiBold"
                                   Foreground="White" Margin="0,0,0,20"/>

                        <Border Background="#2B2D31" CornerRadius="8" Padding="20">
                            <StackPanel>
                                <TextBlock Text="Nextcord"
                                           FontSize="22" FontWeight="Bold"
                                           Foreground="White"/>
                                <TextBlock Text="Version 1.0.0"
                                           Foreground="#80848E" FontSize="13"
                                           Margin="0,4,0,0"/>
                                <Rectangle Height="1" Fill="#3A3C40" Margin="0,16"/>
                                <TextBlock Text="A high-performance Discord client built with .NET 8, CefSharp Chromium, and WPF-UI."
                                           Foreground="#B5BAC1" FontSize="13"
                                           TextWrapping="Wrap"/>
                                <Rectangle Height="1" Fill="#3A3C40" Margin="0,16"/>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="Engine:"    Foreground="#80848E" FontSize="12" Width="80"/>
                                    <TextBlock Text="Chromium via CefSharp 120" Foreground="White" FontSize="12"/>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                                    <TextBlock Text="Framework:" Foreground="#80848E" FontSize="12" Width="80"/>
                                    <TextBlock Text=".NET 8 / WPF"              Foreground="White" FontSize="12"/>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                                    <TextBlock Text="UI Library:" Foreground="#80848E" FontSize="12" Width="80"/>
                                    <TextBlock Text="WPF-UI (Wpf.Ui)"           Foreground="White" FontSize="12"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                    </StackPanel>

                </StackPanel>
            </ScrollViewer>

            <!-- Footer -->
            <Border Grid.Row="1"
                    BorderBrush="#2B2D31" BorderThickness="0,1,0,0"
                    Padding="24,14">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="Cancel" Width="90"
                            Style="{StaticResource CancelBtn}"
                            Margin="0,0,8,0"
                            Click="Cancel_Click"/>
                    <Button Content="Save Changes" Width="120"
                            Style="{StaticResource SaveBtn}"
                            Click="Save_Click"/>
                </StackPanel>
            </Border>

        </Grid>
    </Grid>
</ui:FluentWindow>
